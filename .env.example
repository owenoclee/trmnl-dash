# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Weather location (Open-Meteo — find coords at open-meteo.com)
TRMNL_LAT=
TRMNL_LON=
TRMNL_LOCATION=

# `make deploy` targets (see k8s/README.md). Only needed if you deploy via the
# through-the-node image push for a ClusterIP-only in-cluster registry.
# DEPLOY_HOST=user@your-k3s-node
# REGISTRY_CIP=10.0.0.0:5000
